# Deep Research Agent — environment variables
# Copy to .env and fill in real values. Never commit .env.

# LLM provider — one of: groq, openrouter, ollama, anthropic
LLM_PROVIDER=groq

# LLM provider keys (fill in the one matching LLM_PROVIDER)
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_API_KEY=

# LangSmith observability
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=deep-research-agent

# Search providers
EXA_API_KEY=
TAVILY_API_KEY=

# Cost ceiling — do not raise above 1.00 without explicit approval
COST_CEILING_USD=1.00

# Google Custom Search (optional — used as primary in research mode when set)
# Get API key: https://console.cloud.google.com/ → Custom Search JSON API
# Create CSE: https://programmablesearchengine.google.com/ (search entire web)
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Microsandbox — document rendering sandbox (MSB_SERVER_URL and MSB_API_KEY
# are read automatically by the microsandbox SDK from the environment)
MSB_SERVER_URL=http://localhost:5555
MSB_API_KEY=
